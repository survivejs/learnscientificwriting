{
  "/": {
    "layout": "siteIndex",
    "context": {
      "meta": {
        "title": "Learn scientific writing",
        "ogEyebrow": "LEARN SCIENTIFIC WRITING",
        "ogDescription": "A practical open book about writing clear research articles.",
        "description": "Scientific writing is an art of its own. This site will help you to get started."
      }
    },
    "dataSources": {
      "bookIndex": {
        "operation": "indexBook",
        "parameters": ["./book/chapters.tex", "./book/appendices.tex"]
      }
    }
  },
  "book": {
    "layout": "bookIndex",
    "context": {
      "meta": {
        "title": "The Process of Scientific Writing",
        "ogEyebrow": "LEARN SCIENTIFIC WRITING",
        "ogDescription": "A practical table of contents for the open book.",
        "description": "Table of contents for the book"
      }
    },
    "dataSources": {
      "bookIndex": {
        "operation": "indexBook",
        "parameters": ["./book/chapters.tex", "./book/appendices.tex"]
      },
      "bibtex": {
        "operation": "loadBibtex"
      }
    },
    "routes": {
      "references": {
        "layout": "bookReferences",
        "context": {
          "meta": {
            "title": "References",
            "ogEyebrow": "THE PROCESS OF SCIENTIFIC WRITING",
            "ogDescription": "Works cited throughout the open book.",
            "description": "Works cited in The Process of Scientific Writing"
          }
        },
        "dataSources": {
          "references": {
            "operation": "formatReferences"
          }
        }
      }
    },
    "expand": {
      "matchBy": {
        "name": "chapters",
        "indexer": {
          "operation": "indexBook",
          "parameters": [
            "./book/chapters.tex",
            "./book/appendices.tex",
            { "flatten": true }
          ]
        },
        "slug": "slug"
      },
      "layout": "bookPage",
      "dataSources": {
        "document": {
          "operation": "processChapter"
        }
      },
      "context": {
        "meta": {
          "title": {
            "utility": "get",
            "parameters": ["context", "document.data.title"]
          },
          "description": {
            "utility": "get",
            "parameters": ["context", "document.data.description"]
          },
          "ogEyebrow": {
            "utility": "get",
            "parameters": ["context", "document.data.ogEyebrow"]
          },
          "ogDescription": {
            "utility": "get",
            "parameters": ["context", "document.data.ogDescription"]
          }
        }
      }
    }
  }
}
