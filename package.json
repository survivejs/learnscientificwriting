{
  "type": "module",
  "scripts": {
    "bootstrap": "scripts/bootstrap.sh",
    "fetch:book-repository": "scripts/fetch-book.sh",
    "build": "gustwind --build --output ./build",
    "start": "gustwind --develop --port 3000",
    "serve": "gustwind --serve --port 3000 --input ./build",
    "validate": "gustwind --validate --input ./build"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@tailwindcss/typography": "0.5.19",
    "@twind/core": "1.1.1",
    "@twind/preset-autoprefix": "1.0.5",
    "@twind/preset-tailwind": "1.1.1",
    "@twind/preset-typography": "1.0.5",
    "gustwind": "0.98.0"
  }
}
