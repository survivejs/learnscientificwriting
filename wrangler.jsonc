{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "learnscientificwriting",
  "main": "worker/index.ts",
  "compatibility_date": "2026-04-30",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./build",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
